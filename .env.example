# ============================================================
# KAVACH-07 — Environment Configuration Template
# Copy to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ─── Binance Futures API ────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_here

# true = paper trade testnet | false = live paper signals
USE_TESTNET=true

# ─── Telegram Bot ───────────────────────────────────────────
# Create bot via @BotFather, get chat_id via @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── Trading Parameters ─────────────────────────────────────
INITIAL_BALANCE=1000.0
MAX_RISK_PER_TRADE=0.005       # 0.5% per trade
MAX_TOTAL_EXPOSURE=0.02        # 2% total open risk

# ─── Risk Controls ──────────────────────────────────────────
MAX_SL_PCT=0.08                # Max SL distance 8%
MIN_ATR_PCT=0.001              # Min ATR 0.1% (skip dead markets)
MAX_DAILY_LOSS=0.05            # Halt at -5% daily loss
DRAWDOWN_REDUCE_THRESHOLD=0.10 # Reduce size at 10% drawdown
DRAWDOWN_HALT_THRESHOLD=0.15   # Halt at 15% drawdown

# ─── ML Engine ──────────────────────────────────────────────
ML_CONFIDENCE_THRESHOLD=0.55
ML_MIN_SAMPLES=100
ML_DRIFT_THRESHOLD=0.1

# ─── System ─────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=/var/log/kavach-07.log
HEARTBEAT_INTERVAL=1           # seconds
SCAN_INTERVAL=45               # seconds between signal scans
WS_RECONNECT_DELAY=5           # initial WS reconnect delay
MAX_WS_RECONNECT_DELAY=300     # max WS reconnect delay (5 min)

# ─── Optional: Bybit API for Strategy 10 ────────────────────
# Leave blank to disable cross-exchange arb strategy
BYBIT_API_URL=https://api.bybit.com